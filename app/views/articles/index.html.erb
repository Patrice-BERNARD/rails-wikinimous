<%= render "shared/navbar" %>
<div class="container mt-3">
    <div class="row">
      <% @articles.each  do |article| %>
      <div class="col-sm-8 offset-sm-2">
          <article class="mb-3">
          <h2><%= link_to article.title, article_path(article.id), title: article.title %></h2>
          <%= article.content %>
          </article>
      </div>
      <% end %>
    </div>
  </div>
